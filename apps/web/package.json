{
  "name": "@bt-servant-telemetry/web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:ui": "vite dev",
    "backfill": "wrangler dev --env dev src/scripts/backfill.ts",
    "seed": "wrangler dev src/scripts/seed-dev.ts --port 8788",
    "deploy": "wrangler deploy",
    "build": "svelte-kit sync && vite build && wrangler deploy --dry-run",
    "build:assets": "svelte-kit sync && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-kit sync && tsc --noEmit && tsc --noEmit -p tsconfig.test.json && svelte-check --tsconfig ./tsconfig.sveltekit.json"
  },
  "dependencies": {
    "@bt-servant-telemetry/shared": "workspace:*",
    "@pqina/flip": "^1.6.4",
    "echarts": "^5.6.0",
    "hono": "^4.12.18",
    "svelte-echarts": "^1.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.8",
    "@cloudflare/workers-types": "^4.20260129.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.11.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.4",
    "@tailwindcss/vite": "^4.1.18",
    "mode-watcher": "^1.1.0",
    "svelte": "^5.2.9",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.9",
    "wrangler": "^3.114.17"
  }
}
